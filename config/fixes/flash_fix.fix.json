{
  "id": "flash_fix",
  "label": "Flash Fix Rosbot 2 Pro",
  "enabled": true,
  "description": "Flash firmware and restart docker stack, then rerun diagnostics.",
  "runAtConnection": false,
  "requires": [
    "bash",
    "docker"
  ],
  "sideEffects": "mutating",
  "risk": "high",
  "requiresApproval": true,
  "expectedDowntimeSec": 90,
  "execute": [
    {
      "id": "docker_down",
      "command": "$docker_down$"
    },
    {
      "id": "flash",
      "command": "$flash_firmware$",
      "timeoutSec": 60,
      "saveAs": ""
    },
    {
      "id": "docker_up",
      "command": "$docker_up$"
    },
    {
      "id": "wait",
      "command": "$sleep_20s$"
    }
  ],
  "params": {}
}
