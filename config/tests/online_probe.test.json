{
  "id": "online_probe",
  "label": "Online Probe",
  "description": "Verify the robot is reachable over SSH before deeper diagnostics run.",
  "mode": "online_probe",
  "enabled": true,
  "requires": [
    "ssh"
  ],
  "sideEffects": "read_only",
  "isolation": "definition_shell",
  "checks": [
    {
      "id": "online",
      "metadata": {
        "label": "Online",
        "icon": "🛰️",
        "manualOnly": true,
        "runAtConnection": false,
        "defaultStatus": "warning",
        "defaultValue": "unknown",
        "defaultDetails": "Not checked yet",
        "possibleResults": [
          { "status": "ok", "value": "reachable", "details": "SSH connected and authenticated." },
          { "status": "error", "value": "unreachable", "details": "SSH unavailable or authentication failed." }
        ]
      }
    }
  ]
}
