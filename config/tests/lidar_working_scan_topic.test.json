{
  "id": "lidar_working_scan_topic",
  "label": "Lidar Working",
  "enabled": true,
  "mode": "orchestrate",
  "execute": [
    {
      "id": "step_1",
      "command": "ros topic list",
      "saveAs": "topics_raw"
    }
  ],
  "checks": [
    {
      "id": "lidar_working_scan_topic__scan_present",
      "metadata": {
        "label": "Scan topic present",
        "icon": "L",
        "manualOnly": true,
        "enabled": true,
        "runAtConnection": true,
        "defaultStatus": "warning",
        "defaultValue": "unknown",
        "defaultDetails": "Not checked yet"
      },
      "read": {
        "kind": "contains_any_string",
        "inputRef": "topics_raw",
        "needles": [
          "/scan"
        ],
        "caseSensitive": false
      },
      "pass": {
        "status": "ok",
        "value": "all_present",
        "details": "Lidar scan topic is present in the ROS topic list."
      },
      "fail": {
        "status": "error",
        "value": "missing",
        "details": "Lidar scan topic is missing from the ROS topic list."
      }
    }
  ],
  "params": {}
}
