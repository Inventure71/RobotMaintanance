{
  "id": "persistance_test",
  "label": "Testing Persistance Of Folders",
  "description": "",
  "enabled": true,
  "ownerTags": [
    "global"
  ],
  "platformTags": [],
  "mode": "orchestrate",
  "execute": [
    {
      "id": "step_1",
      "command": "cd snap/",
      "saveAs": "out_1"
    },
    {
      "id": "step_2",
      "command": "ls",
      "saveAs": "out_2"
    }
  ],
  "checks": [
    {
      "id": "persistance_test__found_firefox",
      "metadata": {
        "label": "Found firefox",
        "icon": "\ud83d\udcbe",
        "manualOnly": true,
        "enabled": true,
        "runAtConnection": true,
        "defaultStatus": "warning",
        "defaultValue": "unknown",
        "defaultDetails": "Not checked yet"
      },
      "read": {
        "kind": "contains_string",
        "inputRef": "out_2",
        "needle": "firefox",
        "caseSensitive": false
      },
      "pass": {
        "status": "ok",
        "value": "all_present",
        "details": "Passed"
      },
      "fail": {
        "status": "error",
        "value": "missing",
        "details": "Failed"
      }
    }
  ],
  "params": {}
}
